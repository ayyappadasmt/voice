# ── Gemini (required) ───────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-native-audio-latest
GEMINI_VOICE=Aoede

# ── Web client ──────────────────────────────────────────────────────────
# WebSocket URL the browser uses to reach the backend (used by docker compose
# to build the Next.js app). Use wss:// behind TLS in production.
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/voice

# ── Twilio (optional — only for the phone/V2V channel) ──────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Verify the X-Twilio-Signature header on inbound webhooks (recommended: true)
VALIDATE_TWILIO_SIGNATURE=true

# ── App ─────────────────────────────────────────────────────────────────
# Public HTTPS URL that Twilio uses to reach this service (no trailing slash)
APP_BASE_URL=https://your-domain.example.com

# Optional: token validated before the media stream connects to Gemini.
# Recommended in production. Leave blank to disable.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(24))"
STREAM_AUTH_TOKEN=

# Shared secret staff must enter on the admin page to edit the knowledge base.
# Generate a strong random value, e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
STAFF_API_KEY=change-me-to-a-long-random-secret

# Comma-separated allowed origins for the admin UI (use exact origins in prod).
# Example: https://your-domain.example.com
CORS_ALLOWED_ORIGINS=*
